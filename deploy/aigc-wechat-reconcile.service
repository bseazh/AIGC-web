[Unit]
Description=Bala AIGC daily WeChat Pay reconciliation
After=network.target docker.service
Requires=docker.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/project/AIGC_web
Environment=NODE_ENV=production
EnvironmentFile=-/home/ubuntu/project/AIGC_web/.env.production
ExecStart=/usr/bin/node /home/ubuntu/project/AIGC_web/scripts/wechat-reconcile.mjs
