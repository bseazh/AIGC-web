NEXT_PUBLIC_BASE_PATH=
PORT=3010
HOSTNAME=127.0.0.1
DATABASE_URL=postgresql://aigc:change-me@127.0.0.1:5432/aigc
POSTGRES_PASSWORD=change-me
REDIS_URL=redis://127.0.0.1:6379
SESSION_SECRET=generate-at-least-32-random-bytes
SESSION_COOKIE_SECURE=false
WELCOME_POINTS=100
# 允许进入 /admin/wallets 的账号，使用逗号分隔的邮箱或手机号；留空即关闭后台入口。
ADMIN_IDENTIFIERS=
HERO_IMAGE_TASK_POINTS=10
SCENE_IMAGE_TASK_POINTS=10
MODEL_WEAR_TASK_POINTS=10
HD_ENHANCE_TASK_POINTS=5
DETAIL_PAGE_TASK_POINTS=10
VIDEO_TASK_POINTS=40
ARK_API_KEY=
# 已获授权的火山方舟视频模型，例如 doubao-seedance-2-0-260128。
ARK_MODEL=doubao-seedance-2-0-260128
# 仅用于 npm run verify:ark-video：一张已验证可被方舟访问的 COS 签名图片 URL。
ARK_ACCEPTANCE_INPUT_URL=
# 可覆盖组合验收范围，例如 5,10,15 与 480p,720p,1080p。
ARK_ACCEPTANCE_DURATIONS=5,10,15
ARK_ACCEPTANCE_RESOLUTIONS=480p,720p,1080p
COS_BUCKET=
COS_REGION=
COS_SECRET_ID=
COS_SECRET_KEY=
STORAGE_TEMPORARY_TTL_HOURS=24
STORAGE_UPLOADING_TTL_HOURS=24
STORAGE_INPUT_RETENTION_DAYS=30
STORAGE_OUTPUT_RETENTION_DAYS=90
EMAIL_CODE_SECRET=generate-an-independent-32-character-secret
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USER=bseazh@163.com
SMTP_PASS=use-a-163-client-authorization-code
EMAIL_FROM=芭乐AIGC <bseazh@163.com>
# 微信支付 Native 扫码支付。商户审核通过并完成回调验收前，保持 false。
WECHAT_PAY_ENABLED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY=/home/ubuntu/secrets/wechatpay/apiclient_key.pem
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_PLATFORM_PUBLIC_KEY=/home/ubuntu/secrets/wechatpay/wechatpay_platform.pem
WECHAT_PAY_NOTIFY_URL=https://aigc.bigapple.store/api/payments/wechat/notify/
